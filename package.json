{
  "name": "qoi-viewer",
  "displayName": "QOI Viewer",
  "description": "QOI Viewer for Visual Studio Code",
  "publisher": "Mupceet",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mupceet/qoi-viewer"
  },
  "version": "0.4.0",
  "icon": "images/qoi_logo.png",
  "engines": {
    "vscode": "^1.64.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [ ],
  "main": "./out/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "qoi.previewEditor",
        "displayName": "QOI Viewer",
        "priority": "default",
        "selector": [
          {
            "filenamePattern": "*.qoi"
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "qoiViewer.exportPng",
        "title": "Export as PNG",
        "category": "QOI Viewer"
      },
      {
        "command": "qoiViewer.exportPngFile",
        "title": "Export QOI as PNG",
        "category": "QOI Viewer"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "qoiViewer.exportPng",
          "when": "activeCustomEditorId == 'qoi.previewEditor'"
        },
        {
          "command": "qoiViewer.exportPngFile",
          "when": "false"
        }
      ],
      "explorer/context": [
        {
          "command": "qoiViewer.exportPngFile",
          "when": "resourceExtname == '.qoi'",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "clean": "node -e \"fs.rmSync('out',{recursive:true,force:true})\"",
    "vscode:prepublish": "npm run clean && npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.64.0",
    "typescript": "^5.3.0"
  }
}
